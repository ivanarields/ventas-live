rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: live_sessions
    // Fields: title (string), scheduledAt (string), duration (number), status (string), notes (string)
    //
    // Collection: giveaways
    // Fields: title (string), liveId (string), prize (string), status (string), winnerId (string)
    //
    // Collection: orders
    // Fields: customerName (string), whatsapp (string), total (number), items (string), status (string), paymentMethod (string), createdAt (string)
    //
    // Collection: transactions
    // Fields: type (string), amount (number), category (string), description (string), date (timestamp), isOcr (bool), account (string), beneficiary (string), tags (string), status (string), isRecurring (bool)
    //
    // Collection: pagos
    // Fields: nombre (string), pago (number), date (timestamp), status (string), method (string), verified (bool), customerId (string)
    //
    // Collection: customers
    // Fields: name (string), phone (string), activeLabel (string), totalSpent (number), totalItems (number), pendingItems (number), deliveredItems (number), createdAt (timestamp)
    //
    // Collection: pedidos
    // Fields: customerId (string), date (timestamp), itemCount (number), bagCount (number), label (string), totalAmount (number), status (string), paymentIds (list)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email in ["recluta.grupourkupina@gmail.com", "leidysan.fb@gmail.com"] && request.auth.token.email_verified == true);
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

// Domain Validators
    function isValidTransaction(data) {
      return data.type in ['income', 'expense'] &&
             data.amount is number && data.amount >= 0 &&
             data.category is string &&
             data.description is string &&
             (data.status == null || data.status in ['paid', 'pending']);
    }

    // Rules
    match /live_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /giveaways/{giveawayId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /participants/{participantId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated(); // Anyone can join
        allow update, delete: if isAdmin();
      }
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /transactions/{txId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidTransaction(request.resource.data);
      allow update: if isAdmin() && isValidTransaction(request.resource.data);
      allow delete: if isAdmin();
    }

    match /pagos/{paymentId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin() && request.resource.data.date == resource.data.date;
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /ideas/{ideaId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
